---
<section class="section contact" id="contact">
  <div class="container">
  <h2>Come dance with us</h2>
  <div class="divider"></div>

  <ul class="contact-list">
    <li>
      <span class="label">Studio</span>
      <a href="https://maps.app.goo.gl/WAoLa9m66JbAHYT6A" target="_blank" rel="noopener">
        6425 Redwood Dr<br />Rohnert Park, CA 94928
      </a>
    </li>
    <li>
      <span class="label">Phone</span>
      <a href="tel:+17072934292">707.293.4292</a>
    </li>
    <li>
      <span class="label">Email</span>
      <a href="mailto:salsa@jasdance.com">salsa@jasdance.com</a>
    </li>
  </ul>

  <div class="socials">
    <a href="https://www.facebook.com/salsaandbachata" target="_blank" rel="noopener" aria-label="Facebook">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M13.5 21v-7.5h2.5l.5-3h-3V8.5c0-.87.27-1.5 1.6-1.5H17V4.3c-.3 0-1.3-.1-2.4-.1-2.4 0-4.1 1.5-4.1 4.1v2.2H8v3h2.5V21h3z"/></svg>
    </a>
    <a href="https://instagram.com/bachateuro/" target="_blank" rel="noopener" aria-label="Instagram">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
    </a>
    <a href="https://youtube.com/@JASLATINDANCE" target="_blank" rel="noopener" aria-label="YouTube">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M21.6 7.2c-.2-.9-.9-1.6-1.8-1.8C18.3 5 12 5 12 5s-6.3 0-7.8.4c-.9.2-1.6.9-1.8 1.8C2 8.7 2 12 2 12s0 3.3.4 4.8c.2.9.9 1.6 1.8 1.8 1.5.4 7.8.4 7.8.4s6.3 0 7.8-.4c.9-.2 1.6-.9 1.8-1.8.4-1.5.4-4.8.4-4.8s0-3.3-.4-4.8zM10 15V9l5.2 3-5.2 3z"/></svg>
    </a>
  </div>
  </div>
</section>

<style>
  .contact {
    padding-bottom: 2rem;
  }
  .contact-list {
    list-style: none;
    margin: 1.5rem 0 2.5rem;
  }
  .contact-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .contact-list li:last-child { border-bottom: none; }
  .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    font-weight: 600;
  }
  .contact-list a {
    color: var(--ink);
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .contact-list a:hover { color: var(--accent-bright); }
  .socials {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1rem;
  }
  .socials a {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    transition: all 0.25s;
  }
  .socials a:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
    transform: translateY(-2px);
  }
</style>
