---
interface Props {
  eyebrow?: string;
  title?: string;
}
const { eyebrow = 'Live Calendar', title = "What's Coming Up" } = Astro.props;

// swap this single line to point the embed at a different host:
//   http://localhost:4321  |  https://staging.aglow.life  |  https://aglow.life
const EMBED_BASE = 'https://aglow.life';

const EMBED_SRC = `${EMBED_BASE}/embed?userId=7009eeb4-de44-4022-8d06-6092d3f8bceb,1da9cdf8-dac7-4d56-9f8b-48d48108ba56`;
---
<section class="section aglow-events">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    {title && <h2>{title}</h2>}
    <div class="divider"></div>
  </div>
  <iframe
    id="aglow-events-frame"
    src={EMBED_SRC}
    data-origin={EMBED_BASE}
    title="aglow events"
    loading="lazy"
  ></iframe>
</section>

<script>
  const frame = document.getElementById(
    'aglow-events-frame',
  ) as HTMLIFrameElement | null;

  // origin to validate postMessages against — kept in sync with EMBED_BASE
  // via the data-origin attribute, so there's only one host to change.
  const ORIGIN = frame?.dataset.origin;

  // the embed broadcasts its content height on load and reflow; size the iframe
  // to match so there's no inner scrollbar or empty gap.
  window.addEventListener('message', (e: MessageEvent) => {
    if (e.origin !== ORIGIN) return;
    if (e.source !== frame?.contentWindow) return;
    const data = e.data;
    if (data?.type === 'aglow-embed:height' && typeof data.height === 'number') {
      frame.style.height = `${data.height}px`;
    }
  });
</script>

<style>
  #aglow-events-frame {
    display: block;
    width: 100%;
    /* fallback before the first postMessage (and if JS is disabled) */
    height: 720px;
    border: 0;
    background: transparent;
    margin-top: 1.5rem;
  }
</style>
