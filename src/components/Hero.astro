---
<section class="hero">
  <div class="hero-content">
    <p class="hero-tag">Inspiring One Dance At A Time</p>
    <div class="divider hero-divider"></div>
    <p class="hero-sub">Bachata · Salsa · Latin Dance</p>
    <a href="#events" class="btn hero-cta">See What's On</a>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    isolation: isolate;
  }
  .hero-content {
    text-align: center;
    padding: 2.5rem 1.5rem 3rem;
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    animation: fadeUp 1s ease-out;
  }
  .hero-tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.8rem, 7vw, 2.4rem);
    color: var(--ink);
    margin-bottom: 1rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }
  .hero-divider {
    margin: 1.25rem auto;
  }
  .hero-sub {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 2rem;
  }
  .hero-cta {
    margin-top: 0.5rem;
  }
  .hero-scroll {
    width: 24px;
    height: 36px;
    border: 1.5px solid var(--ink-dim);
    border-radius: 12px;
    opacity: 0.6;
    margin: 0 auto 2rem;
  }
  .hero-scroll span {
    display: block;
    width: 2px;
    height: 6px;
    background: var(--ink-dim);
    margin: 6px auto 0;
    animation: scrollDot 1.8s infinite;
  }
  @keyframes scrollDot {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(10px); opacity: 0.3; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
