---
const year = new Date().getFullYear();
---
<footer class="footer">
  <p>© {year} JAS Latin Dance Academy</p>
  <p class="tag">Inspiring one dance at a time</p>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 2.5rem 1.5rem 3rem;
    border-top: 1px solid var(--border);
    color: var(--ink-dim);
    font-size: 0.85rem;
  }
  .footer .tag {
    margin-top: 0.5rem;
    font-style: italic;
    color: var(--accent);
    font-family: var(--font-display);
  }
</style>
