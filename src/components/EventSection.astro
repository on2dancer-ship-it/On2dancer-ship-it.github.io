---
interface Props {
  title: string;
  date: string;
  location: string;
  description: string;
  ctaUrl: string;
  ctaLabel?: string;
  imageSrc: string;
  eyebrow?: string;
  featured?: boolean;
}
const {
  title,
  date,
  location,
  description,
  ctaUrl,
  ctaLabel = 'Learn More',
  imageSrc,
  eyebrow,
  featured = false,
} = Astro.props;
---
<section class="event">
  <div class="event-hero">
    <img src={imageSrc} alt={title} />
  </div>
  <div class="event-body">
    <div class="container">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2>{title}</h2>
      <div class="divider"></div>
      <p class="meta meta-date">{date}</p>
      <p class="meta meta-loc">{location}</p>
      <p class="desc">{description}</p>
      <a href={ctaUrl} class={`btn ${featured ? 'btn-solid' : ''}`} target="_blank" rel="noopener">
        {ctaLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .event {
    width: 100%;
  }
  .event-hero {
    width: 100%;
    background: var(--bg);
  }
  .event-hero img {
    width: 100%;
    height: auto;
    display: block;
  }
  .event-body {
    padding: 3rem 0 4rem;
  }
  h2 {
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .meta {
    font-size: 0.95rem;
    color: var(--accent);
    margin: 0.35rem 0;
    font-weight: 500;
  }
  .meta-loc {
    color: var(--ink-dim);
    font-weight: 400;
  }
  .desc {
    margin: 1.25rem 0 1.75rem;
    color: var(--ink-dim);
  }
</style>
