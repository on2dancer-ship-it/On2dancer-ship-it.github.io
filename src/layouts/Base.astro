---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'JAS Latin Dance Academy — Inspiring One Dance At A Time',
  description = 'JAS Latin Dance Academy: bachata, salsa, and Latin dance instruction in Rohnert Park and San Francisco. Classes, socials, and signature events.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0606" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/bachateuro.jpg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrapper">
      <slot />
    </div>
  </body>
</html>
